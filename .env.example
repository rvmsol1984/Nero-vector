# Azure AD multi-tenant app registration credentials
# The app must be consented in every tenant listed in tenants.json
# and hold the ActivityFeed.Read application permission for the
# Office 365 Management API.
VECTOR_CLIENT_ID=replace-with-app-registration-client-id
VECTOR_CLIENT_SECRET=replace-with-app-registration-client-secret

# PostgreSQL connection (shares the Hetzner stack Postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nero_vector
POSTGRES_USER=nero_vector
POSTGRES_PASSWORD=replace-with-strong-password

# Path inside the container to the tenants config file
VECTOR_TENANTS_FILE=/app/tenants.json

# Poll interval in seconds (default 300 = 5 minutes)
VECTOR_POLL_INTERVAL=300

# Log level: DEBUG, INFO, WARNING, ERROR
VECTOR_LOG_LEVEL=INFO

# Shared secret for the INKY MailShield webhook. The inky-receiver
# FastAPI process on port 3007 timing-safe-compares the X-Vector-Token
# header against this value. If unset, the endpoint fails closed with
# 503. VECTOR_INKY_TOKEN is accepted as a legacy alias.
INKY_WEBHOOK_SECRET=replace-with-a-long-random-string
VECTOR_INKY_TOKEN=replace-with-a-long-random-string

# Session secret for the auth-server (Express PKCE sidecar). Must be a
# long random string; PKCE state cookies are invalidated whenever it
# rotates. Required.
SESSION_SECRET=replace-with-a-long-random-string

# JWT signing secret shared between the auth-server (issuer) and the
# FastAPI vector-ui backend (verifier on /api/*). Must be a long random
# string. Rotating it invalidates every live session immediately.
JWT_SECRET=replace-with-a-long-random-string

# Microsoft redirect URI. Must exactly match the value registered on
# the Azure AD app registration.
AUTH_REDIRECT_URI=https://vector.rvmsol.com/auth/callback
