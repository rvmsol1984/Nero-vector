# Azure AD multi-tenant app registration credentials
# The app must be consented in every tenant listed in tenants.json
# and hold the ActivityFeed.Read application permission for the
# Office 365 Management API.
VECTOR_CLIENT_ID=replace-with-app-registration-client-id
VECTOR_CLIENT_SECRET=replace-with-app-registration-client-secret

# PostgreSQL connection (shares the Hetzner stack Postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nero_vector
POSTGRES_USER=nero_vector
POSTGRES_PASSWORD=replace-with-strong-password

# Path inside the container to the tenants config file
VECTOR_TENANTS_FILE=/app/tenants.json

# Poll interval in seconds (default 300 = 5 minutes)
VECTOR_POLL_INTERVAL=300

# Log level: DEBUG, INFO, WARNING, ERROR
VECTOR_LOG_LEVEL=INFO

# Shared secret for the INKY MailShield webhook. Required for
# POST /api/ingest/inky on the vector-ui service. If unset the endpoint
# fails closed with 503 so it can't be exposed accidentally.
VECTOR_INKY_TOKEN=replace-with-a-long-random-string

# Session secret for the auth-server (Express PKCE sidecar). Must be a
# long random string; cookies are invalidated whenever it rotates. The
# auth-server refuses to start if this is unset.
SESSION_SECRET=replace-with-a-long-random-string
